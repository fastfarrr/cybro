<?xml version="1.0" encoding="utf-8" ?>
<odoo>
   <data>
       <record id="invoice_email_template" model="mail.template">
           <field name="name">Invoice email</field>
           <field name="model_id" ref="account.model_account_move"/>
           <field name="subject">Invoice "{{ object.name }}"</field>
           <field name="email_from">{{object.user_id.partner_id.email}}</field>
           <field name="body_html" type="html">
               <div style="margin: 0px; padding: 0px;">
                   <p style="margin: 0px; padding: 0px; font-size: 13px;">
                       Hello,<span style="font-weight: bold;" t-out="object.student_id.student_name"/>
                       <br/>
                       <br/>
                       Here is your invoice <span style="font-weight: bold;" t-out="object.name"/> please check into it and confirm everything is alright<br/>
                       Invoice amount is <span t-out="object.amount_total"/>
                   </p>
               </div>
           </field>
           <field name="lang">{{ object.user_id.partner_id.lang or object.user_id.lang }}</field>
           <field name="auto_delete" eval="True"/>
       </record>
   </data>
</odoo>