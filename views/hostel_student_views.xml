<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    form view-->
    <record id="hostel_room_view_form" model="ir.ui.view">
        <field name="name">hostel.room.view.form</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                           options="{'clickable':1}"/>
                </header>
                <sheet>
                      <group>
                            <h1>
                                <field name="room_number" readonly="1"/>
                            </h1>
                        </group>
                    <group>
                        <group>
                            <field name="room_type"/>
                            <field name="number_of_beds"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="rent"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    list view-->

    <record id="hostel_room_list_view" model="ir.ui.view">
        <field name="name">hostel_room_list_view</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <list>

                <field name="room_number"/>
                <field name="room_type"/>
                <field name="number_of_beds"/>
                <field name="rent"/>
                <field name="state"/>
            </list>

        </field>
    </record>
    <!--    action-->

    <record id="hostel_room_action" model="ir.actions.act_window">
        <field name="name">Hostel form</field>
        <field name="res_model">hostel.room</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p>create your first data</p>
        </field>
    </record>




</odoo>