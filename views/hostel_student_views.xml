<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!--  search view -->
    <record id="hostel_room_search_view" model="ir.ui.view">
        <field name="name">Custom search view</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <search string="Room search">
                <field name="number_of_beds"/>
                <field name="room_type"/>
                <field name="state"/>
                <filter name="rooms_available" string="Rooms available"
                        domain="[('state', 'in' , ['empty','partial','cleaning'])]"/>
                <group>
                    <filter string="Count of bed" name="count_of_beds"
                            context="{'group_by' : 'number_of_beds'}"/>
                </group>
            </search>
        </field>
    </record>


    <!--    form view-->
    <record id="hostel_room_view_form" model="ir.ui.view">
        <field name="name">hostel.room.view.form</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                    <!--                           options="{'clickable':1}"/>-->
                    <button type="object" class="oe_highlight"
                            string="Monthly invoice" name="monthly_invoice"/>

                </header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil">
                            <field name="invoice_count" widget="statinfo"
                                   string="Invoices"/>
                        </button>
                    </div>
                    <group>
                        <h1>
                            <field name="room_number" readonly="1"/>
                        </h1>
                    </group>
                    <group>
                        <group>
                            <field name="room_type"/>
                            <field name="number_of_beds"/>
                            <field name="company_id"/>
                            <field name="facilities_ids"
                                   widget="many2many_tags"/>
                            <!--                            <field name="cleaning_staff"/>-->
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="rent" widget="monetary"/>
                            <field name="state"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_rent"/>
                            <field name="pending_amount"/>

                        </group>
                    </group>
                    <group>
                        <notebook>

                            <page string="student details"
                                  name="student_details">
                                <group>
                                    <field name="student_ids" nolabel="1"/>
                                </group>
                            </page>


                        </notebook>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    list view-->

    <record id="hostel_room_list_view" model="ir.ui.view">
        <field name="name">hostel_room_list_view</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <list>


                <field name="room_number"/>
                <field name="room_type"/>
                <field name="number_of_beds"/>
                <field name="rent"/>
                <field name="state"/>

            </list>

        </field>
    </record>
    <!--    action-->


    <record id="hostel_room_action" model="ir.actions.act_window">
        <field name="name">Hostel room</field>
        <field name="res_model">hostel.room</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'search_default_rooms_available': 1}</field>
        <field name="help" type="html">
            <p>create your first data</p>
        </field>
    </record>


</odoo>