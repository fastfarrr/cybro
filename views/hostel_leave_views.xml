<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="leave_request_form_view" model="ir.ui.view">
        <field name="name">Leave date</field>
        <field name="model">leave_request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"/>
                    <button type="object" string="Approve" class="oe_highlight"
                                name="approve" invisible="status == 'approved'"/>
                </header>
                <sheet>
                    <group>

                        <field name="student_id"/>
                        <field name="leave_date"/>
                        <field name="arrival_date"/>
<!--                        <field name="status"/>-->
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="leave_request_list_view" model="ir.ui.view">
        <field name="name">Leave date</field>
        <field name="model">leave_request</field>
        <field name="arch" type="xml">
            <list>
                <field name="leave_date" width="85px"/>
                <field name="arrival_date" width="85px"/>
                <field name="status" width="85px"/>
            </list>
        </field>
    </record>

    <record id="leave_request_action" model="ir.actions.act_window">
        <field name="name">Leave request</field>
        <field name="res_model">leave_request</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p>create your first leave</p>
        </field>
    </record>
</odoo>
