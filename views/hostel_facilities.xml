<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="hostel_facility_form_view" model="ir.ui.view">
        <field name="name">hostel.facilities.form.view</field>
        <field name="model">hostel.facilities</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="charge"/>
                        <field name="currency_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hostel_facility_list_view" model="ir.ui.view">
        <field name="name">hostel.facilities.list.view</field>
        <field name="model">hostel.facilities</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="charge"/>
            </list>
        </field>
    </record>

    <record id="hostel_facilities_action" model="ir.actions.act_window">
        <field name="name">Hostel facilities</field>
        <field name="res_model">hostel.facilities</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p>create your first facility</p>
        </field>
    </record>
</odoo>